rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'manikanta5sy@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ------------------------------------------------------------
    // PRODUCTS COLLECTION
    // ------------------------------------------------------------
    match /products/{productId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------
    // USERS COLLECTION
    // ------------------------------------------------------------
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /cart/{cartId} { allow read, write: if isOwner(userId); }
      match /wishlist/{wishlistId} { allow read, write: if isOwner(userId); }
      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin() || (isOwner(userId) && incoming().keys().hasAny(['read', 'dismissedNotifications', 'updatedAt', 'lastReadNotification']));
      }
    }

    // ------------------------------------------------------------
    // ORDERS COLLECTION
    // ------------------------------------------------------------
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(existing().userId) && incoming().status == 'cancelled');
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------
    // REVIEWS COLLECTION
    // ------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // ------------------------------------------------------------
    // GLOBAL NOTIFICATIONS
    // ------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------
    // BANNERS COLLECTION
    // ------------------------------------------------------------
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------
    // SETTINGS COLLECTION
    // ------------------------------------------------------------
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------
    // ADMINS COLLECTION
    // ------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ------------------------------------------------------------
    // COUPONS COLLECTION
    // ------------------------------------------------------------
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------
    // GLOBAL SAFETY NET
    // ------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
