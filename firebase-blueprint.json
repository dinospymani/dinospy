{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including preferences and role.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "lastReadNotification": { "type": "string", "format": "date-time" },
        "dismissedNotifications": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role"]
    },
    "Product": {
      "title": "Watch Product",
      "description": "Details about a luxury watch.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Luxury", "Sport", "Smart", "Classic"] },
        "description": { "type": "string" },
        "images": { "type": "array" },
        "videoUrl": { "type": "string" },
        "specs": { "type": "object" },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isTrending": { "type": "boolean" },
        "isLimited": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "brand", "price", "category", "images", "stock"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "Information about a watch purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "A product in a user's cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "quantity"]
    },
    "Review": {
      "title": "Product Review",
      "description": "Customer feedback on a watch.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A saved watch for later.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Banner": {
      "title": "Promotion Banner",
      "description": "Banners for home page offers and new arrivals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "displayDesktop": { "type": "boolean", "default": true },
        "displayMobile": { "type": "boolean", "default": true },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "title", "active"]
    },
    "Offer": {
      "title": "Scrolling Offer",
      "description": "Short text offers that scroll on the homepage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "active"]
    },
    "Notification": {
      "title": "App Notification",
      "description": "Global or user-specific notifications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["offer", "trending", "new_arrival", "general", "order", "security", "promotion"] },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "createdAt"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "Support inquiry from a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "RESOLVED", "CLOSED"] },
        "lastMessage": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "unreadByAdmin": { "type": "boolean" },
        "unreadByUser": { "type": "boolean" }
      },
      "required": ["userId", "subject", "status"]
    },
    "SupportMessage": {
      "title": "Support Message",
      "description": "Individual message in a support ticket.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "admin"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "timestamp", "sender"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Watch product directory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/users/{userId}/cart/{cartId}": {
      "schema": "CartItem",
      "description": "User shopping cart items."
    },
    "/users/{userId}/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User wishlist."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Homepage promotional banners."
    },
    "/offers/{offerId}": {
      "schema": "Offer",
      "description": "Scrolling announcement offers."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global application notifications."
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Support ticket metadata."
    },
    "/support_tickets/{ticketId}/messages/{messageId}": {
      "schema": "SupportMessage",
      "description": "Support ticket messages."
    }
  }
}
